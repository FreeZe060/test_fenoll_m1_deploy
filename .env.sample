# ============================================================
# SECRETS GITHUB ACTIONS - A configurer dans :
# GitHub > Settings > Secrets and variables > Actions
# ============================================================

# --- AWS Credentials (IAM) ---
AWS_ACCESS_KEY_ID=AKIA...             # Access Key ID de l'utilisateur IAM
AWS_SECRET_ACCESS_KEY=...             # Secret Access Key de l'utilisateur IAM
# Si compte AWS Academy (cles temporaires) :
# AWS_SESSION_TOKEN=...               # Session Token (optionnel, uniquement AWS Academy)

# --- Registre Docker Prive (EC2 Registry) ---
REGISTRY_IP=15.224.107.173            # IP publique de l'EC2 du registre Docker
REGISTRY_USER=admin                   # Identifiant du registre
REGISTRY_PASSWORD=admin123            # Mot de passe du registre

# --- Base de donnees (MySQL) ---
DB_PASSWORD=...                       # Mot de passe MySQL pour l'application

# ============================================================
# CONNEXION AU REGISTRE DOCKER PRIVE
# ============================================================
# URL      : https://15.224.107.173:443
# Login    : admin
# Password : admin123
#
# Commande de connexion (ignorer le certificat auto-signe) :
# docker login 15.224.107.173:443 --username admin --password admin123
# ============================================================
